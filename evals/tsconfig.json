{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "noEmit": true,
    "moduleResolution": "bundler",
    "strict": true
  },
  "include": [
    "**/app/**/*.ts",
    "**/app/**/*.tsx",
    "**/example/**/*.ts",
    "**/example/**/*.tsx",
    "**/reference/**/*.ts",
    "**/reference/**/*.tsx"
  ]
}
